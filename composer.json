{
  "name": "brainstudnl/laravel-job-tracker",
  "description": "Track Laravel jobs in your application. With link to subjects, status and more.",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Brainstud\\LaravelJobTracker\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Brainstud\\LaravelJobTracker\\Tests\\": "tests",
      "Workbench\\App\\": "workbench/app/",
      "Workbench\\Database\\Factories\\": "workbench/database/factories/",
      "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
    }
  },
  "authors": [
    {
      "name": "brdv"
    }
  ],
  "require": {
    "php": "^8.3",
    "laravel/framework": "^12.0 || ^13.0",
    "brainstud/has-identifier": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.4",
    "laravel/pint": "^1.29",
    "orchestra/testbench": "^v11.1.0",
    "spatie/laravel-ray": "^1.37"
  },
  "scripts": {
    "test": "./vendor/bin/phpunit",
    "lint": [
      "vendor/bin/pint"
    ]
  }
}
